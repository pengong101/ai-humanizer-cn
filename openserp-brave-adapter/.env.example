# OpenSERP Brave Adapter 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# 服务端口
PORT=8765

# OpenSERP 后端地址
OPENSERP_BASE_URL=http://localhost:8080

# OpenSERP API 密钥（如果后端需要认证）
OPENSERP_API_KEY=

# Brave API 密钥验证（设为 dummy-key 禁用验证）
BRAVE_API_KEY=dummy-key

# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# 请求超时时间（毫秒）
REQUEST_TIMEOUT=10000

# 是否启用 CORS
ENABLE_CORS=true
